{
  "name": "dinboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:din-rail-regression": "vitest run src/lib/dinRailSnap.test.ts src/lib/dinRailSelection.test.ts src/hooks/useSymbolActions.test.ts",
    "smoke:online": "node scripts/online-smoke.mjs",
    "smoke:production": "node scripts/online-smoke.mjs",
    "check": "npm run build && npm run test",
    "check:online": "npm run check && npm run smoke:online"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@pixi/react": "^8.0.5",
    "@react-pdf/renderer": "^4.5.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "buffer": "^6.0.3",
    "dompurify": "^3.4.7",
    "lucide-react": "^1.17.0",
    "mobile-drag-drop": "^3.0.0-rc.0",
    "pixi.js": "^8.18.1",
    "process": "^0.11.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
