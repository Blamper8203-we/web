{
  "name": "dinboard-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": "24.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc && vite-react-ssg build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:din-rail-regression": "vitest run src/lib/dinRailSnap.test.ts src/lib/dinRailSelection.test.ts src/hooks/useSymbolActions.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke:online": "node scripts/online-smoke.mjs",
    "smoke:production": "node scripts/online-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run build && npm run test",
    "check:online": "npm run check && npm run smoke:online"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@react-pdf/renderer": "^4.5.1",
    "@tauri-apps/api": "^2.11.0",
    "@vercel/analytics": "^2.0.1",
    "buffer": "^6.0.3",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "mobile-drag-drop": "^3.0.0-rc.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vite-react-ssg": "^0.9.1-beta.1",
    "vitest": "^4.1.7"
  }
}
